<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                  https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
      Lombok-generated constructors, builders, and setters trigger EI_EXPOSE_REP2
      because they store references directly. Defensive copying would break JPA
      dirty tracking and Spring MVC deserialization — intentional pattern.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
      UserPrincipal implements UserDetails (Serializable) but the application is
      stateless (JWT, no HTTP sessions). Serialization of the principal is never used.
    -->
    <Match>
        <Class name="com.boilerplate.infrastructure.security.UserPrincipal"/>
        <Bug pattern="SE_BAD_FIELD,SE_NO_SERIALVERSIONID"/>
    </Match>

    <!--
      CorsConfig uses @Value-injected fields that cannot be initialised in a
      constructor without a matching @ConfigurationProperties binding.
    -->
    <Match>
        <Class name="com.boilerplate.infrastructure.config.CorsConfig"/>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
    </Match>

</FindBugsFilter>
